# Server
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# Required: OpenAI-compatible provider used to generate constrained test plans.
# OPENAI_BASE_URL must include the provider's /v1 prefix when required.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-provider-api-key
OPENAI_MODEL=gpt-4.1-mini

# GitHub App registration metadata. The current MVP consumes signed webhooks;
# installation-token authentication will use these values in Phase 3.
GITHUB_APP_ID=
GITHUB_APP_SLUG=runzaai
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=./runzaai.private-key.pem

# Required when GitHub webhook integration is enabled.
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret

# HTTPS relay used for local GitHub webhook development. Run `npm run dev:github`
# beside `npm run dev` to forward deliveries to the local webhook route.
GITHUB_WEBHOOK_PROXY_URL=https://smee.io/replace-with-channel-id

# Required for webhook-triggered PR runs unless CI supplies the
# x-freebug-target-url header with a deployed preview/staging URL.
GITHUB_TARGET_URL=https://preview.example.com

# Required: Convex deployment URL used by POST /v1/waitlist.
# Use the deployment URL from the Convex dashboard, for example https://name.convex.cloud.
CONVEX_URL=https://your-deployment.convex.cloud

# Local artifact persistence. The directory is created automatically.
ARTIFACT_DIR=./data/artifacts

# PR runs fan out to these planning agents, then execute all merged cases in
# one ephemeral Daytona sandbox. Use a snapshot with Node 22 + Playwright
# Chromium for faster starts; otherwise the official Playwright image is used.
PLANNER_AGENTS=smoke,functional,accessibility
DAYTONA_API_KEY=replace-with-daytona-api-key
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=us
# DAYTONA_SNAPSHOT=freebug-playwright
DAYTONA_TIMEOUT_SECONDS=900

# When set, every video, trace, screenshot, generated script, and report uploads
# to GCS using Application Default Credentials.
GCS_BUCKET=replace-with-gcs-bucket
GCS_PREFIX=freebug
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Optional URL prefix when bucket objects are exposed through a CDN/public host.
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/replace-with-gcs-bucket

# Optional: completion emails. When empty, notifications are logged instead.
# Example: smtps://username:password@smtp.example.com:465
SMTP_URL=
SMTP_FROM="Freebug <noreply@example.com>"

# Dodo Payments (required together when billing is enabled)
BILLING_ENABLED=false
DODO_ENVIRONMENT=test_mode
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_STARTER_PRODUCT_ID=
DODO_SCALE_PRODUCT_ID=
# Choose integer credit allocations and per-run cost for your business model.
DODO_STARTER_CREDITS=
DODO_SCALE_CREDITS=
RUN_CREDIT_COST=
DODO_RETURN_URL=http://localhost:3000
